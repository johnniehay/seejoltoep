{
  "name": "seejolapp",
  "version": "1.0.0",
  "description": "Website template for Payload",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build && cp -r public .next/standalone/ && cp -r .next/static .next/standalone/.next/",
    "build-compile": "next build --experimental-build-mode compile && cp -r public .next/standalone/ && cp -r .next/static .next/standalone/.next/",
    "buildonly": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "buildserwist": "cross-env NODE_OPTIONS=--no-deprecation serwist build",
    "next": "cross-env NODE_OPTIONS=--no-deprecation next",
    "postbuild": "next-sitemap --config next-sitemap.config.cjs",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "dev:prod": "cross-env NODE_OPTIONS=--no-deprecation rm -rf .next && pnpm build && pnpm start",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "ii": "cross-env NODE_OPTIONS=--no-deprecation pnpm --ignore-workspace install",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation next lint",
    "lint:fix": "cross-env NODE_OPTIONS=--no-deprecation next lint --fix",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "payload-noenv": "payload",
    "reinstall": "cross-env NODE_OPTIONS=--no-deprecation rm -rf node_modules && rm pnpm-lock.yaml && pnpm --ignore-workspace install",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --no-experimental-strip-types\" pnpm exec playwright test --config=playwright.config.ts",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts",
    "build:auth-lib": "tsc -b src/lib/payload-authjs-custom/tsconfig.json && cp \"src/lib/payload-authjs-custom/payload/components/SignInButton/index.css\" src/lib/payload-authjs-custom/dist/payload/components/SignInButton/"
  },
  "dependencies": {
    "@auth/core": "^0.34.3",
    "@delmaredigital/payload-puck": "^0.6.25",
    "@hookform/resolvers": "^5.4.0",
    "@marsidev/react-turnstile": "^1.5.2",
    "@next/third-parties": "^16.2.6",
    "@payloadcms/admin-bar": "3.84.1",
    "@payloadcms/db-mongodb": "3.84.1",
    "@payloadcms/email-nodemailer": "^3.84.1",
    "@payloadcms/live-preview-react": "3.84.1",
    "@payloadcms/next": "3.84.1",
    "@payloadcms/plugin-ecommerce": "^3.84.1",
    "@payloadcms/plugin-form-builder": "3.84.1",
    "@payloadcms/plugin-nested-docs": "3.84.1",
    "@payloadcms/plugin-redirects": "3.84.1",
    "@payloadcms/plugin-search": "3.84.1",
    "@payloadcms/plugin-seo": "3.84.1",
    "@payloadcms/richtext-lexical": "3.84.1",
    "@payloadcms/ui": "3.84.1",
    "@puckeditor/core": "^0.21.2",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-switch": "^1.2.6",
    "@simplewebauthn/browser": "^9.0.1",
    "@simplewebauthn/server": "^9.0.3",
    "@tabler/icons-react": "^3.44.0",
    "@types/nodemailer": "^8.0.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "date-fns": "^4.3.0",
    "dexie": "^4.4.2",
    "dotenv": "17.4.2",
    "embla-carousel-react": "^8.6.0",
    "geist": "^1.7.1",
    "google-auth-library": "^10.6.2",
    "googleapis": "^172.0.0",
    "graphql": "^16.14.0",
    "lodash": "^4.18.1",
    "lucide-react": "^0.577.0",
    "next": "16.2.6",
    "next-auth": "5.0.0-beta.30",
    "next-safe-action": "^8.5.3",
    "next-sitemap": "^4.2.3",
    "nodemailer": "^8.0.8",
    "payload": "3.84.1",
    "prism-react-renderer": "^2.3.1",
    "qrcode.react": "^4.2.0",
    "qs-esm": "^8.0.1",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-hook-form": "7.76.1",
    "react-intersection-observer": "^10.0.3",
    "sharp": "0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.1",
    "tailwindcss-animate": "^1.0.7",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@part-db/html5-qrcode": "file:vendor/part-db-html5-qrcode-4.0.1-prerelease.tgz",
    "@playwright/test": "1.60.0",
    "@serwist/cli": "^9.5.11",
    "@serwist/next": "^9.5.11",
    "@simplewebauthn/types": "^9.0.1",
    "@tailwindcss/typography": "^0.5.13",
    "@testing-library/react": "16.3.2",
    "@types/escape-html": "^1.0.2",
    "@types/lodash": "^4.17.24",
    "@types/node": "24.12.4",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "6.0.2",
    "autoprefixer": "^10.5.0",
    "copyfiles": "^2.4.1",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.6",
    "jsdom": "29.1.1",
    "playwright": "1.60.0",
    "playwright-core": "1.60.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "serwist": "^9.5.11",
    "tailwindcss": "^3.4.19",
    "typescript": "6.0.3",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.7"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9 || ^10 || ^11"
  }
}
